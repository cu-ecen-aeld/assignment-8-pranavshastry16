#!/bin/sh
#
# S98lddmodules
#
# SysV init script for Assignment 8.
#
# Purpose:
#   - Load the aesdchar kernel module at boot
#   - Create /dev/aesdchar if needed
#   - Set permissions so testing is easier
#   - Unload the module at shutdown
#
# Why S98?
#   - This runs late in boot, after most of the system is up
#   - We want the kernel module loaded before aesdsocket starts
#

case "$1" in
    start)
        echo "Loading aesdchar module..."

        #
        # If Buildroot installed the module in the usual "extra" directory,
        # load it directly with insmod.
        #
        if [ -f /lib/modules/$(uname -r)/extra/aesdchar.ko ]; then
            insmod /lib/modules/$(uname -r)/extra/aesdchar.ko || true
        else
            #
            # Otherwise try modprobe, which consults module metadata.
            #
            modprobe aesdchar || true
        fi

        #
        # Create the /dev/aesdchar character device node manually.
        # Buildroot images do not always auto-create custom device nodes.
        #
        AESDCHAR_MAJOR=$(awk '$2=="aesdchar" {print $1}' /proc/devices)

        if [ -n "$AESDCHAR_MAJOR" ]; then
            mknod /dev/aesdchar c $AESDCHAR_MAJOR 0 2>/dev/null
            chmod 666 /dev/aesdchar 2>/dev/null
        fi
        ;;

    stop)
        echo "Unloading aesdchar module..."

        #
        # Suppress error if module is already removed or was never loaded.
        #
        rmmod aesdchar 2>/dev/null || true
        ;;

    restart)
        #
        # Standard SysV restart behavior
        #
        $0 stop
        $0 start
        ;;

    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
